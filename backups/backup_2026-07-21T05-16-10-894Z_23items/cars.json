"\u003c!DOCTYPE html\u003e\r\n\u003chtml lang=\"th\"\u003e\r\n\u003chead\u003e\r\n  \u003cmeta charset=\"UTF-8\"\u003e\r\n  \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\r\n  \u003ctitle\u003eระบบขออนุมัติใช้รถยนต์และเบิกจ่าย - องค์การสะพานปลา\u003c/title\u003e\r\n  \u003clink rel=\"stylesheet\" href=\"flatpickr.min.css?v=1.0\"\u003e\r\n  \u003clink rel=\"stylesheet\" href=\"style.css?v=5.2\"\u003e\r\n\u003c/head\u003e\r\n\u003cbody\u003e\r\n  \u003c!-- MAINTENANCE SCREEN (Overlay) --\u003e\r\n  \u003cdiv id=\"system-maintenance-overlay\" class=\"maintenance-overlay\"\u003e\r\n    \u003cscript\u003e\r\n      if (localStorage.getItem(\u0027system_active\u0027) === \u0027true\u0027) {\r\n        document.getElementById(\u0027system-maintenance-overlay\u0027).classList.add(\u0027hidden\u0027);\r\n      }\r\n    \u003c/script\u003e\r\n    \u003cdiv class=\"maintenance-card\"\u003e\r\n      \u003cdiv class=\"maintenance-icon\"\u003e🔒\u003c/div\u003e\r\n      \u003ch2\u003eระบบยังไม่เปิดใช้งาน\u003c/h2\u003e\r\n      \u003cp\u003eระบบจองใช้ยานพาหนะและเบิกจ่ายค่าพาหนะ องค์การสะพานปลา (FMO)\u003cbr\u003eขณะนี้ยังไม่เปิดให้บริการอย่างเป็นทางการ\u003c/p\u003e\r\n      \r\n      \u003c!-- Activation Form (hidden by default) --\u003e\r\n      \u003cdiv id=\"activation-login-box\" class=\"hidden\" style=\"width: 100%; display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem;\"\u003e\r\n        \u003cinput type=\"text\" id=\"activation-username\" class=\"form-control\" placeholder=\"ชื่อผู้ใช้งาน (Username)\" style=\"background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); color: white; padding: 0.6rem; border-radius: 8px;\"\u003e\r\n        \u003cinput type=\"password\" id=\"activation-password\" class=\"form-control\" placeholder=\"รหัสผ่าน (Password)\" style=\"background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); color: white; padding: 0.6rem; border-radius: 8px;\"\u003e\r\n        \u003cdiv style=\"display: flex; gap: 0.5rem; margin-top: 0.25rem;\"\u003e\r\n          \u003cbutton type=\"button\" class=\"btn btn-secondary\" id=\"btn-cancel-activation\" style=\"flex: 1; padding: 0.6rem; border-radius: 8px; border-color: rgba(255,255,255,0.2); color: white; background: transparent;\"\u003eยกเลิก\u003c/button\u003e\r\n          \u003cbutton type=\"button\" class=\"btn btn-primary\" id=\"btn-submit-activation\" style=\"flex: 1; padding: 0.6rem; border-radius: 8px; background: #10b981; border-color: #10b981; color: white;\"\u003eตกลง\u003c/button\u003e\r\n        \u003c/div\u003e\r\n      \u003c/div\u003e\r\n\r\n      \u003cbutton class=\"btn btn-primary\" id=\"btn-activate-system\" style=\"background: #f59e0b; border-color: #f59e0b; margin-top: 1rem; font-weight: bold; width: 100%; padding: 0.75rem;\"\u003e\r\n        🔑 เปิดใช้งานระบบ\r\n      \u003c/button\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n\r\n  \u003c!-- Background Blobs for Glassmorphism depth --\u003e\r\n  \u003cdiv class=\"bg-blob blob-1\"\u003e\u003c/div\u003e\r\n  \u003cdiv class=\"bg-blob blob-2\"\u003e\u003c/div\u003e\r\n\r\n  \u003c!-- LOGIN SCREEN (Overlay) --\u003e\r\n  \u003cdiv id=\"login-screen\" class=\"login-overlay hidden\"\u003e\r\n    \u003cdiv class=\"login-card\" style=\"box-shadow: var(--shadow-lg); position: relative;\"\u003e\r\n      \u003cbutton type=\"button\" id=\"btn-close-login\" style=\"position: absolute; top: 1rem; right: 1.25rem; background: transparent; border: none; color: var(--text-muted); font-size: 1.75rem; cursor: pointer; line-height: 1; transition: var(--transition-smooth); z-index: 10;\" onmouseover=\"this.style.color=\u0027var(--text-main)\u0027\" onmouseout=\"this.style.color=\u0027var(--text-muted)\u0027\"\u003e\u0026times;\u003c/button\u003e\r\n      \u003cdiv class=\"login-header\"\u003e\r\n        \u003cimg src=\"logoFMO.png\" alt=\"โลโก้ อสป.\" style=\"width: 90px; height: 90px; margin-bottom: 0.5rem; object-fit: contain;\"\u003e\r\n        \u003ch2\u003eองค์การสะพานปลา\u003c/h2\u003e\r\n        \u003cp\u003eระบบขออนุมัติและจองใช้รถยนต์ภายในองค์กร\u003c/p\u003e\r\n      \u003c/div\u003e\r\n      \u003cform id=\"form-login\"\u003e\r\n        \u003cdiv class=\"form-group\"\u003e\r\n          \u003clabel for=\"login-username\"\u003eชื่อผู้ใช้งาน (Username)\u003c/label\u003e\r\n          \u003cinput type=\"text\" id=\"login-username\" class=\"form-control\" placeholder=\"ระบุชื่อผู้ใช้งาน เช่น siranya.w\" required\u003e\r\n        \u003c/div\u003e\r\n        \u003cdiv class=\"form-group\"\u003e\r\n          \u003clabel for=\"login-password\"\u003eรหัสผ่าน (รหัสพนักงาน)\u003c/label\u003e\r\n          \u003cinput type=\"password\" id=\"login-password\" class=\"form-control\" placeholder=\"ระบุรหัสพนักงาน 8 หลัก\" required\u003e\r\n        \u003c/div\u003e\r\n        \u003cbutton type=\"submit\" class=\"btn btn-primary\" style=\"width: 100%; margin-top: 0.5rem; margin-bottom: 0.5rem;\"\u003e🔓 เข้าสู่ระบบ\u003c/button\u003e\r\n      \u003c/form\u003e\r\n\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n\r\n  \u003c!-- APP CONTAINER (Always visible layout structure) --\u003e\r\n  \u003cdiv class=\"app-container\" id=\"app-wrapper\"\u003e\r\n    \r\n    \u003c!-- Sidebar Navigation --\u003e\r\n    \u003caside class=\"sidebar no-print\"\u003e\r\n      \u003cdiv class=\"logo-section\"\u003e\r\n        \u003cimg src=\"logoFMO.png\" alt=\"โลโก้ อสป.\" style=\"width: 45px; height: 45px; object-fit: contain; background: white; padding: 2px; border-radius: 6px;\"\u003e\r\n        \u003cdiv class=\"logo-text\"\u003e\r\n          \u003ch1\u003eองค์การสะพานปลา\u003c/h1\u003e\r\n          \u003cp\u003eระบบขออนุญาตใช้รถยนต์\u003c/p\u003e\r\n        \u003c/div\u003e\r\n      \u003c/div\u003e\r\n      \r\n      \u003cnav class=\"nav-menu\"\u003e\r\n        \u003cli class=\"nav-item\"\u003e\r\n          \u003ca href=\"#\" class=\"nav-link\" data-view=\"dashboard\" id=\"nav-dashboard\"\u003e\r\n            \u003cspan class=\"nav-icon\"\u003e📊\u003c/span\u003e\r\n            \u003cspan class=\"nav-text\"\u003eแดชบอร์ดภาพรวม\u003c/span\u003e\r\n          \u003c/a\u003e\r\n        \u003c/li\u003e\r\n        \u003cli class=\"nav-item\"\u003e\r\n          \u003ca href=\"#\" class=\"nav-link\" data-view=\"bookings\" id=\"nav-bookings\"\u003e\r\n            \u003cspan class=\"nav-icon\"\u003e📋\u003c/span\u003e\r\n            \u003cspan class=\"nav-text\"\u003eรายการจอง \u0026 อนุมัติ\u003c/span\u003e\r\n            \u003cspan id=\"pending-badge-count\" class=\"menu-badge\"\u003e0\u003c/span\u003e\r\n          \u003c/a\u003e\r\n        \u003c/li\u003e\r\n        \u003cli class=\"nav-item\"\u003e\r\n          \u003ca href=\"#\" class=\"nav-link active\" data-view=\"calendar\" id=\"nav-calendar\"\u003e\r\n            \u003cspan class=\"nav-icon\"\u003e📅\u003c/span\u003e\r\n            \u003cspan class=\"nav-text\"\u003eปฏิทินจองใช้รถ\u003c/span\u003e\r\n          \u003c/a\u003e\r\n        \u003c/li\u003e\r\n        \u003cli class=\"nav-item hidden\" id=\"nav-item-driver-report\"\u003e\r\n          \u003ca href=\"#\" class=\"nav-link\" data-view=\"driver-report\" id=\"nav-driver-report\"\u003e\r\n            \u003cspan class=\"nav-icon\"\u003e📊\u003c/span\u003e\r\n            \u003cspan class=\"nav-text\"\u003eรายงานการใช้งาน พขร.\u003c/span\u003e\r\n          \u003c/a\u003e\r\n        \u003c/li\u003e\r\n      \u003c/nav\u003e\r\n\r\n    \u003c/aside\u003e\r\n\r\n    \u003c!-- Main Container --\u003e\r\n    \u003cmain class=\"main-content\"\u003e\r\n      \r\n      \u003c!-- Top header bar --\u003e\r\n  \u003cheader class=\"topbar no-print\" style=\"display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem;\"\u003e\r\n      \r\n      \u003cdiv class=\"page-title\"\u003e\r\n        \u003ch2 id=\"view-title\"\u003eรายการจองรถยนต์\u003c/h2\u003e\r\n        \u003cp id=\"view-subtitle\"\u003eจัดการ อนุมัติ และติดตามความคืบหน้าคำขอทั้งหมด\u003c/p\u003e\r\n      \u003c/div\u003e\r\n\r\n      \u003cdiv class=\"header-actions\" style=\"display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; width: 320px; flex-shrink: 0;\"\u003e\r\n        \r\n        \u003cbutton class=\"btn btn-primary\" id=\"btn-top-login\"\u003eเข้าสู่ระบบ\u003c/button\u003e\r\n\r\n        \u003cdiv id=\"header-user-profile\" class=\"header-user-profile\" style=\"flex-direction: column; align-items: stretch; gap: 0.75rem; background: rgba(255,255,255,0.65); padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid var(--border-color); margin: 0; width: 100%;\"\u003e\r\n          \u003cdiv style=\"display: flex; align-items: center; gap: 0.75rem;\"\u003e\r\n            \u003cdiv id=\"email-inbox-trigger\" style=\"position: relative; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.75); border-radius: 50%; width: 36px; height: 36px; border: 1px solid var(--border-color);\"\u003e\r\n              \u003cspan\u003e🔔\u003c/span\u003e\r\n              \u003cspan id=\"email-inbox-badge\" style=\"position: absolute; top: -5px; right: -5px; background: var(--danger); color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.7rem; font-weight: bold; display: none;\"\u003e0\u003c/span\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"avatar\" id=\"user-avatar\"\u003e?\u003c/div\u003e\r\n            \u003cdiv class=\"user-info\"\u003e\r\n              \u003cspan class=\"user-name\" id=\"user-display-name\"\u003eผู้ใช้\u003c/span\u003e\r\n              \u003cspan class=\"user-role-badge\" id=\"user-role-label\"\u003eตำแหน่ง\u003c/span\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n          \u003cbutton class=\"btn btn-secondary btn-sm hidden\" id=\"btn-deactivate-system\" style=\"width: 100%; color: #f59e0b; border-color: rgba(245, 158, 11, 0.2); font-weight: bold; margin-bottom: 0.25rem;\"\u003e\r\n            🔒 ปิดใช้งานระบบชั่วคราว\r\n          \u003c/button\u003e\r\n          \u003cbutton class=\"btn btn-secondary btn-sm\" id=\"btn-logout\" style=\"width: 100%; color: var(--danger); border-color: rgba(220, 38, 38, 0.2);\"\u003e\r\n            🚪 ออกจากระบบ\r\n          \u003c/button\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003cdiv id=\"approval-level-container\" class=\"hidden\" style=\"display: none; width: 100%;\"\u003e\r\n  \u003cselect id=\"approval-level-switcher\" class=\"form-control\" style=\"width: 100%; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--primary-color); background-color: #f8fafc; color: var(--primary-color); font-weight: bold;\"\u003e\r\n    \u003coption value=\"all\"\u003eแสดงงานอนุมัติทั้งหมด\u003c/option\u003e\r\n  \u003c/select\u003e\r\n\u003c/div\u003e\r\n\r\n\u003cscript\u003e\r\n  if (!localStorage.getItem(\u0027current_user\u0027)) {\r\n    document.getElementById(\u0027approval-level-container\u0027).style.display = \u0027none\u0027;\r\n    document.getElementById(\u0027approval-level-container\u0027).classList.add(\u0027hidden\u0027);\r\n  }\r\n\u003c/script\u003e\r\n\r\n        \u003cbutton class=\"btn btn-primary hidden\" id=\"btn-open-booking\" style=\"width: 100%; justify-content: center;\"\u003e\r\n          \u003cspan\u003e+\u003c/span\u003e เขียนใบขออนุญาตใช้รถ\r\n        \u003c/button\u003e\r\n\r\n      \u003c/div\u003e\r\n    \u003c/header\u003e\r\n\r\n      \u003c!-- VIEW 1: Dashboard --\u003e\r\n      \u003csection id=\"view-dashboard\" class=\"view-section hidden\"\u003e\r\n        \r\n        \u003c!-- AUTHENTICATED DASHBOARD CONTENT --\u003e\r\n        \u003cdiv id=\"dashboard-main-widgets\"\u003e\r\n          \r\n          \u003c!-- Stats Row --\u003e\r\n          \u003cdiv class=\"stats-grid\"\u003e\r\n            \u003cdiv class=\"stat-card\"\u003e\r\n              \u003cdiv class=\"stat-icon primary\"\u003e🚘\u003c/div\u003e\r\n              \u003cdiv class=\"stat-details\"\u003e\r\n                \u003cspan class=\"stat-value\" id=\"stat-total-cars\"\u003e3 คัน\u003c/span\u003e\r\n                \u003cspan class=\"stat-label\"\u003eรถยนต์ของ อสป.\u003c/span\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"stat-card success\"\u003e\r\n              \u003cdiv class=\"stat-icon success\"\u003e🟢\u003c/div\u003e\r\n              \u003cdiv class=\"stat-details\"\u003e\r\n                \u003cspan class=\"stat-value\" id=\"stat-avail-cars\"\u003e3 คัน\u003c/span\u003e\r\n                \u003cspan class=\"stat-label\"\u003eว่างพร้อมปฏิบัติงาน\u003c/span\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"stat-card warning\"\u003e\r\n              \u003cdiv class=\"stat-icon warning\"\u003e⏳\u003c/div\u003e\r\n              \u003cdiv class=\"stat-details\"\u003e\r\n                \u003cspan class=\"stat-value\" id=\"stat-pending-approvals\"\u003e0 รายการ\u003c/span\u003e\r\n                \u003cspan class=\"stat-label\"\u003eรอคุณตรวจสอบ\u003c/span\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"stat-card danger\"\u003e\r\n              \u003cdiv class=\"stat-icon danger\"\u003e📝\u003c/div\u003e\r\n              \u003cdiv class=\"stat-details\"\u003e\r\n                \u003cspan class=\"stat-value\" id=\"stat-total-bookings\"\u003e0 รายการ\u003c/span\u003e\r\n                \u003cspan class=\"stat-label\"\u003eใบขอใช้รถทั้งหมด\u003c/span\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Fleet Grid --\u003e\r\n          \u003cdiv class=\"fleet-section\" style=\"margin-top: 2rem;\"\u003e\r\n            \u003cdiv class=\"section-header\"\u003e🚘 สถานะยานพาหนะของ อสป.\u003c/div\u003e\r\n            \u003cdiv class=\"car-grid\" id=\"car-list-container\"\u003e\r\n              \u003c!-- Car cards injected here --\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Scheduler Visual Timeline --\u003e\r\n          \u003cdiv class=\"schedule-container\" style=\"margin-top: 2rem;\"\u003e\r\n            \u003cdiv class=\"schedule-header\"\u003e\r\n              \u003cdiv class=\"section-header\"\u003e📅 ตารางการใช้รถวันนี้\u003c/div\u003e\r\n              \u003cdiv class=\"timeline-legend\"\u003e\r\n                \u003cdiv class=\"legend-item\"\u003e\u003cspan class=\"legend-dot available\"\u003e\u003c/span\u003e ว่าง\u003c/div\u003e\r\n                \u003cdiv class=\"legend-item\"\u003e\u003cspan class=\"legend-dot pending\"\u003e\u003c/span\u003e รออนุมัติ\u003c/div\u003e\r\n                \u003cdiv class=\"legend-item\"\u003e\u003cspan class=\"legend-dot approved\"\u003e\u003c/span\u003e อนุมัติแล้ว\u003c/div\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"schedule-grid\" id=\"timeline-scheduler-container\"\u003e\r\n              \u003c!-- Timeline details injected via JavaScript --\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n\r\n      \u003c/section\u003e\r\n\r\n       \u003c!-- VIEW 2: Bookings List and Approvals --\u003e\r\n      \u003csection id=\"view-bookings\" class=\"view-section hidden no-print\"\u003e\r\n        \u003cdiv class=\"tab-container\"\u003e\r\n          \u003cdiv class=\"tab-nav\" style=\"display: flex; gap: 2rem; border-bottom: 1px solid var(--border-color); width: 100%; margin-bottom: 1.5rem; align-items: center; flex-wrap: wrap;\"\u003e\r\n            \u003cbutton class=\"tab-btn active\" data-tab=\"tab-my-bookings\"\u003eรายการที่ฉันขอ (\u003cspan id=\"tab-my-bookings-count\"\u003e0\u003c/span\u003e)\u003c/button\u003e\r\n            \u003cbutton class=\"tab-btn\" data-tab=\"tab-pending-approvals\"\u003eงานรออนุมัติจากคุณ (\u003cspan id=\"tab-pending-count\"\u003e0\u003c/span\u003e)\u003c/button\u003e\r\n            \u003cbutton class=\"tab-btn\" data-tab=\"tab-all-history\"\u003eประวัติทั้งหมด (\u003cspan id=\"tab-all-history-count\"\u003e0\u003c/span\u003e)\u003c/button\u003e\r\n            \u003cbutton class=\"btn btn-secondary btn-sm\" id=\"btn-export-csv\" onclick=\"openExportModal()\" style=\"margin-left: auto; height: 32px; padding: 0 0.75rem; display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; background: #10b981; color: white; border-color: #10b981; margin-bottom: 0.5rem; cursor: pointer; border-radius: 6px; font-weight: bold; border-style: solid; border-width: 1px;\"\u003e\r\n              📥 ส่งออก Excel (CSV)\r\n            \u003c/button\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Tab 1: My Bookings --\u003e\r\n          \u003cdiv id=\"tab-my-bookings\" class=\"tab-content active\"\u003e\r\n            \u003cdiv class=\"booking-list\" id=\"my-bookings-container\"\u003e\r\n              \u003c!-- Injected dynamically --\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Tab 2: Pending Approvals (For managers/admin) --\u003e\r\n          \u003cdiv id=\"tab-pending-approvals\" class=\"tab-content\"\u003e\r\n            \u003cdiv class=\"booking-list\" id=\"pending-approvals-container\"\u003e\r\n              \u003c!-- Injected dynamically --\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Tab 3: All History --\u003e\r\n          \u003cdiv id=\"tab-all-history\" class=\"tab-content\"\u003e\r\n            \u003cdiv class=\"booking-list\" id=\"all-history-container\"\u003e\r\n              \u003c!-- Injected dynamically --\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n      \u003c/section\u003e\r\n\r\n      \u003c!-- VIEW 3: Printable Report --\u003e\r\n      \u003csection id=\"view-report\" class=\"view-section hidden\"\u003e\r\n        \u003c!-- Actions above the report sheet --\u003e\r\n        \u003cdiv class=\"report-actions-bar no-print\"\u003e\r\n          \u003cbutton class=\"btn btn-secondary\" id=\"btn-report-back\"\u003e← กลับ\u003c/button\u003e\r\n          \u003cdiv style=\"font-weight: 500; font-size: 0.9rem; color: var(--text-muted);\"\u003e\r\n            ฟอร์มเสนออนุมัติ/เบิกจ่ายอย่างเป็นทางการขององค์การสะพานปลา\r\n          \u003c/div\u003e\r\n          \u003cbutton class=\"btn btn-primary\" id=\"btn-report-print\"\u003e🖨️ พิมพ์เอกสาร (Print / Save PDF)\u003c/button\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003c!-- The printable paper container --\u003e\r\n        \u003cdiv class=\"report-sheet\" id=\"report-sheet-content\"\u003e\r\n          \u003c!-- Injected dynamically --\u003e\r\n        \u003c/div\u003e\r\n      \u003c/section\u003e\r\n\r\n      \u003c!-- VIEW 5: Driver Report --\u003e\r\n      \u003csection id=\"view-driver-report\" class=\"view-section hidden\"\u003e\r\n        \u003c!-- Actions above the report sheet --\u003e\r\n        \u003cdiv class=\"report-actions-bar no-print\"\u003e\r\n          \u003cbutton class=\"btn btn-secondary\" id=\"btn-driver-report-back\"\u003e← กลับ\u003c/button\u003e\r\n          \u003cdiv style=\"font-weight: 500; font-size: 0.9rem; color: var(--text-muted);\"\u003e\r\n            รายงานการปฏิบัติงานใช้รถของพนักงานขับรถรายบุคคล\r\n          \u003c/div\u003e\r\n          \u003cbutton class=\"btn btn-primary\" id=\"btn-driver-report-print\"\u003e🖨️ พิมพ์รายงาน (Print / Save PDF)\u003c/button\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003c!-- Filters Section - Visible only in app, not in print --\u003e\r\n        \u003cdiv class=\"driver-report-filters no-print card-glass\" style=\"margin-bottom: 2rem; padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border-color); background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(16px);\"\u003e\r\n          \u003ch3 style=\"margin-top: 0; margin-bottom: 1rem; font-size: 1.1rem; color: var(--text-main); display: flex; align-items: center; gap: 8px;\"\u003e\r\n            \u003cspan\u003e🔍\u003c/span\u003e ค้นหาและออกรายงาน พขร.\r\n          \u003c/h3\u003e\r\n          \u003cdiv class=\"driver-report-filter-grid\"\u003e\r\n            \u003cdiv\u003e\r\n              \u003clabel style=\"display: block; font-size: 0.8rem; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 500;\"\u003eเลือกพนักงานขับรถ\u003c/label\u003e\r\n              \u003cselect id=\"driver-report-select\" class=\"form-control\" style=\"width: 100%;\"\u003e\u003c/select\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv\u003e\r\n              \u003clabel style=\"display: block; font-size: 0.8rem; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 500;\"\u003eช่วงเวลาของรายงาน\u003c/label\u003e\r\n              \u003cselect id=\"driver-report-period\" class=\"form-control\" style=\"width: 100%;\"\u003e\r\n                \u003coption value=\"daily\"\u003eรายวัน (Daily)\u003c/option\u003e\r\n                \u003coption value=\"weekly\"\u003eรายสัปดาห์ (Weekly)\u003c/option\u003e\r\n                \u003coption value=\"monthly\" selected\u003eรายเดือน (Monthly)\u003c/option\u003e\r\n              \u003c/select\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv id=\"driver-report-date-container\" class=\"hidden\"\u003e\r\n              \u003clabel id=\"driver-report-date-label\" style=\"display: block; font-size: 0.8rem; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 500;\"\u003eเลือกวัน\u003c/label\u003e\r\n              \u003cinput type=\"date\" id=\"driver-report-date\" class=\"form-control\" style=\"width: 100%;\"\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv id=\"driver-report-month-container\"\u003e\r\n              \u003clabel style=\"display: block; font-size: 0.8rem; margin-bottom: 0.5rem; color: var(--text-muted); font-weight: 500;\"\u003eเลือกเดือน/ปี\u003c/label\u003e\r\n              \u003cdiv style=\"display: flex; gap: 0.5rem;\"\u003e\r\n                \u003cselect id=\"driver-report-month\" class=\"form-control\" style=\"flex: 2;\"\u003e\r\n                  \u003coption value=\"0\"\u003eมกราคม\u003c/option\u003e\r\n                  \u003coption value=\"1\"\u003eกุมภาพันธ์\u003c/option\u003e\r\n                  \u003coption value=\"2\"\u003eมีนาคม\u003c/option\u003e\r\n                  \u003coption value=\"3\"\u003eเมษายน\u003c/option\u003e\r\n                  \u003coption value=\"4\"\u003eพฤษภาคม\u003c/option\u003e\r\n                  \u003coption value=\"5\"\u003eมิถุนายน\u003c/option\u003e\r\n                  \u003coption value=\"6\"\u003eกรกฎาคม\u003c/option\u003e\r\n                  \u003coption value=\"7\"\u003eสิงหาคม\u003c/option\u003e\r\n                  \u003coption value=\"8\"\u003eกันยายน\u003c/option\u003e\r\n                  \u003coption value=\"9\"\u003eตุลาคม\u003c/option\u003e\r\n                  \u003coption value=\"10\"\u003eพฤศจิกายน\u003c/option\u003e\r\n                  \u003coption value=\"11\"\u003eธันวาคม\u003c/option\u003e\r\n                \u003c/select\u003e\r\n                \u003cselect id=\"driver-report-year\" class=\"form-control\" style=\"flex: 1.2;\"\u003e\r\n                  \u003coption value=\"2026\"\u003e2569\u003c/option\u003e\r\n                  \u003coption value=\"2027\"\u003e2570\u003c/option\u003e\r\n                \u003c/select\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv\u003e\r\n              \u003cbutton class=\"btn btn-primary\" id=\"btn-generate-driver-report\" style=\"width: 100%; display: flex; align-items: center; justify-content: center; gap: 6px; font-weight: bold; height: 42px;\"\u003e\r\n                \u003cspan\u003e📊\u003c/span\u003e ดึงข้อมูลรายงาน\r\n              \u003c/button\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003c!-- The printable paper container --\u003e\r\n        \u003cdiv class=\"report-sheet\" id=\"driver-report-sheet-content\"\u003e\r\n          \u003cdiv style=\"text-align: center; color: var(--text-muted); padding: 3rem 0; font-style: italic;\"\u003e\r\n            กรุณาเลือกพนักงานขับรถและช่วงเวลา จากนั้นกดปุ่ม \"ดึงข้อมูลรายงาน\" เพื่อสร้างรายงานการวิ่งรถยนต์\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n      \u003c/section\u003e\r\n\r\n      \u003c!-- VIEW 4: Full Month Calendar --\u003e\r\n      \u003csection id=\"view-calendar\" class=\"view-section no-print\"\u003e\r\n        \u003cdiv class=\"calendar-view-container\"\u003e\r\n          \u003cdiv class=\"calendar-top-controls\"\u003e\r\n            \u003cdiv class=\"calendar-month-nav\"\u003e\r\n              \u003cbutton class=\"btn btn-secondary\" id=\"btn-cal-prev\" style=\"padding:0.4rem 0.8rem;\"\u003e← เดือนก่อนหน้า\u003c/button\u003e\r\n              \u003ch3 class=\"calendar-month-title\" id=\"calendar-month-year-label\"\u003eมิถุนายน 2569\u003c/h3\u003e\r\n              \u003cbutton class=\"btn btn-secondary\" id=\"btn-cal-next\" style=\"padding:0.4rem 0.8rem;\"\u003eเดือนถัดไป →\u003c/button\u003e\r\n            \u003c/div\u003e\r\n            \r\n            \u003cdiv style=\"display:flex; gap:1rem; align-items:center;\"\u003e\r\n              \u003clabel for=\"filter-cal-car\" style=\"font-size:0.875rem; font-weight:600; white-space:nowrap;\"\u003eกรองตามรถยนต์:\u003c/label\u003e\r\n              \u003cselect id=\"filter-cal-car\" class=\"role-select\" style=\"min-width:180px; padding:0.4rem; background: var(--bg-card);\"\u003e\r\n                \u003coption value=\"all\"\u003eรถยนต์ทั้งหมด\u003c/option\u003e\r\n                \u003coption value=\"A\"\u003eToyota Commuter (ฮษ 7446)\u003c/option\u003e\r\n                \u003coption value=\"B\"\u003eToyota Commuter (1 นญ 1865 (เช่า))\u003c/option\u003e\r\n                \u003coption value=\"C\"\u003eToyota Commuter (1 นญ 2029 (เช่า))\u003c/option\u003e\r\n                \u003coption value=\"D\"\u003eToyota Commuter (ฮล 2521 (รถสวัสดิการ))\u003c/option\u003e\r\n                \u003coption value=\"public\"\u003eรถรับจ้างสาธารณะ\u003c/option\u003e\r\n              \u003c/select\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Month Calendar Grid --\u003e\r\n          \u003cdiv class=\"calendar-grid-wrapper\"\u003e\r\n            \u003cdiv class=\"calendar-days-header\"\u003e\r\n              \u003cdiv class=\"calendar-header-day sun\"\u003eอาทิตย์\u003c/div\u003e\r\n              \u003cdiv class=\"calendar-header-day\"\u003eจันทร์\u003c/div\u003e\r\n              \u003cdiv class=\"calendar-header-day\"\u003eอังคาร\u003c/div\u003e\r\n              \u003cdiv class=\"calendar-header-day\"\u003eพุธ\u003c/div\u003e\r\n              \u003cdiv class=\"calendar-header-day\"\u003eพฤหัสบดี\u003c/div\u003e\r\n              \u003cdiv class=\"calendar-header-day\"\u003eศุกร์\u003c/div\u003e\r\n              \u003cdiv class=\"calendar-header-day sat\"\u003eเสาร์\u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"calendar-grid-cells\" id=\"calendar-cells-container\"\u003e\r\n              \u003c!-- Injected dynamically via JS --\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n      \u003c/section\u003e\r\n\r\n    \u003c/main\u003e\r\n  \u003c/div\u003e\r\n\r\n  \u003c!-- MODAL 1: Create Booking Form --\u003e\r\n  \u003cdiv class=\"modal-overlay\" id=\"modal-booking\"\u003e\r\n    \u003cdiv class=\"modal-box\" style=\"max-width: 700px;\"\u003e\r\n      \u003cdiv class=\"modal-header\"\u003e\r\n        \u003ch3\u003eเขียนใบขออนุญาตใช้รถยนต์ อสป.\u003c/h3\u003e\r\n        \u003cbutton class=\"modal-close\" id=\"btn-close-booking\"\u003e\u0026times;\u003c/button\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"modal-body\"\u003e\r\n        \u003cform id=\"form-create-booking\"\u003e\r\n          \r\n          \u003ch4 style=\"color: var(--primary); margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.25rem;\"\u003eข้อมูลผู้ขอจอง\u003c/h4\u003e\r\n          \u003cdiv class=\"form-row\"\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-requester\"\u003eชื่อผู้ขอจอง (ข้าพเจ้า)\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-requester\" class=\"form-control\" placeholder=\"ชื่อ-นามสกุล\" required\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-position\"\u003eตำแหน่ง\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-position\" class=\"form-control\" placeholder=\"ตำแหน่ง\" required\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-row\"\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-department\"\u003eแผนก\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-department\" class=\"form-control\" placeholder=\"แผนก\" required\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-office\"\u003eสำนักงาน\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-office\" class=\"form-control\" placeholder=\"สำนักงาน\" required\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-division\"\u003eสังกัด/ฝ่าย\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-division\" class=\"form-control\" placeholder=\"สังกัด/ฝ่าย\" required\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-group\"\u003e\r\n            \u003clabel\u003eขออนุญาตใช้รถยนต์ในความควบคุมของสำนักงานบริหารการพัสดุเพื่อติดต่องาน\u003c/label\u003e\r\n            \u003cdiv style=\"display: flex; gap: 1.5rem; margin-top: 0.5rem; flex-wrap: wrap;\"\u003e\r\n              \u003clabel style=\"display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: normal;\"\u003e\r\n                \u003cinput type=\"radio\" name=\"control-unit\" value=\"อสป.\" checked style=\"accent-color: var(--primary);\"\u003e อสป.\r\n              \u003c/label\u003e\r\n              \u003clabel style=\"display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: normal;\"\u003e\r\n                \u003cinput type=\"radio\" name=\"control-unit\" value=\"สินเชื่อ\" style=\"accent-color: var(--primary);\"\u003e สินเชื่อ\r\n              \u003c/label\u003e\r\n              \u003clabel style=\"display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: normal;\"\u003e\r\n                \u003cinput type=\"radio\" name=\"control-unit\" value=\"ส่งเสริมการประมง\" style=\"accent-color: var(--primary);\"\u003e ส่งเสริมการประมง\r\n              \u003c/label\u003e\r\n              \u003clabel style=\"display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: normal;\"\u003e\r\n                \u003cinput type=\"radio\" name=\"control-unit\" value=\"รถสวัสดิการ\" style=\"accent-color: var(--primary);\"\u003e รถสวัสดิการ\r\n              \u003c/label\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003c!-- Welfare Car Address Info (Visible only for Welfare Car) --\u003e\r\n          \u003cdiv id=\"welfare-address-container\" style=\"display: none; margin-top: 1rem; border: 1px dashed var(--border-color); padding: 1rem; border-radius: 8px; background: rgba(255,255,255,0.02);\"\u003e\r\n            \u003ch5 style=\"color: var(--primary); margin: 0 0 0.75rem 0; font-size: 0.95rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.25rem;\"\u003eข้อมูลที่อยู่ผู้ขอใช้รถยนต์สวัสดิการ (ใช้สำหรับกรอกใบคำขอ)\u003c/h5\u003e\r\n            \u003cdiv class=\"form-row\" style=\"margin-bottom: 0.75rem;\"\u003e\r\n              \u003cdiv class=\"form-group\" style=\"margin-bottom: 0;\"\u003e\r\n                \u003clabel for=\"input-welfare-address-no\"\u003eอยู่บ้านเลขที่\u003c/label\u003e\r\n                \u003cinput type=\"text\" id=\"input-welfare-address-no\" class=\"form-control\" placeholder=\"เช่น 123/45\"\u003e\r\n              \u003c/div\u003e\r\n              \u003cdiv class=\"form-group\" style=\"margin-bottom: 0;\"\u003e\r\n                \u003clabel for=\"input-welfare-address-moo\"\u003eหมู่ที่\u003c/label\u003e\r\n                \u003cinput type=\"text\" id=\"input-welfare-address-moo\" class=\"form-control\" placeholder=\"เช่น 5\"\u003e\r\n              \u003c/div\u003e\r\n              \u003cdiv class=\"form-group\" style=\"margin-bottom: 0;\"\u003e\r\n                \u003clabel for=\"input-welfare-address-road\"\u003eถนน\u003c/label\u003e\r\n                \u003cinput type=\"text\" id=\"input-welfare-address-road\" class=\"form-control\" placeholder=\"เช่น เจริญกรุง\"\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-row\"\u003e\r\n              \u003cdiv class=\"form-group\" style=\"margin-bottom: 0;\"\u003e\r\n                \u003clabel for=\"input-welfare-address-subdistrict\"\u003eตำบล/แขวง\u003c/label\u003e\r\n                \u003cinput type=\"text\" id=\"input-welfare-address-subdistrict\" class=\"form-control\" placeholder=\"เช่น วัดพระยาไกร\"\u003e\r\n              \u003c/div\u003e\r\n              \u003cdiv class=\"form-group\" style=\"margin-bottom: 0;\"\u003e\r\n                \u003clabel for=\"input-welfare-address-district\"\u003eอำเภอ/เขต\u003c/label\u003e\r\n                \u003cinput type=\"text\" id=\"input-welfare-address-district\" class=\"form-control\" placeholder=\"เช่น บางคอแหลม\"\u003e\r\n              \u003c/div\u003e\r\n              \u003cdiv class=\"form-group\" style=\"margin-bottom: 0;\"\u003e\r\n                \u003clabel for=\"input-welfare-address-province\"\u003eจังหวัด\u003c/label\u003e\r\n                \u003cinput type=\"text\" id=\"input-welfare-address-province\" class=\"form-control\" placeholder=\"เช่น กรุงเทพมหานคร\"\u003e\r\n              \u003c/div\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003ch4 style=\"color: var(--primary); margin-top: 1.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.25rem;\"\u003eรายละเอียดการเดินทาง\u003c/h4\u003e\r\n          \u003cdiv class=\"form-group\"\u003e\r\n            \u003clabel for=\"input-purpose\"\u003eเรื่อง (วัตถุประสงค์)\u003c/label\u003e\r\n            \u003cinput type=\"text\" id=\"input-purpose\" class=\"form-control\" placeholder=\"ระบุเรื่องเพื่อติดต่องาน\" required\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-row\"\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-destination\"\u003eสถานที่ปลายทาง\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-destination\" class=\"form-control\" placeholder=\"ระบุสถานที่ปลายทาง\" required\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-ref\"\u003eที่ (อ้างอิงเอกสาร)\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-ref\" class=\"form-control\" placeholder=\"เช่น อสป. 102/2569\"\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-group\"\u003e\r\n            \u003clabel for=\"input-passengers\"\u003eโดยมีผู้โดยสารไปรถคือ (ระบุชื่อทั้งหมด คั่นด้วยเครื่องหมายจุลภาค ,)\u003c/label\u003e\r\n            \u003cinput type=\"text\" id=\"input-passengers\" class=\"form-control\" placeholder=\"ระบุชื่อพนักงานผู้เดินทางร่วม\" required\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-row\"\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-start-date\"\u003eตั้งแต่วันที่\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-start-date\" class=\"form-control\" required\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-end-date\"\u003eจนถึงวันที่\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"input-end-date\" class=\"form-control\" required\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"input-trips\"\u003eจำนวนเที่ยว\u003c/label\u003e\r\n              \u003cinput type=\"number\" id=\"input-trips\" class=\"form-control\" value=\"2\" min=\"1\" readonly style=\"background-color: rgba(255, 255, 255, 0.05); opacity: 0.85; cursor: not-allowed;\" required\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003ch4 style=\"color: var(--primary); margin-top: 1.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.25rem;\"\u003eประเภทพาหนะที่เสนอขอ\u003c/h4\u003e\r\n          \u003cdiv class=\"form-group\" style=\"background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 1rem; border-radius: 8px;\"\u003e\r\n            \u003cdiv id=\"vehicle-request-tip\" style=\"font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem; background: rgba(255,255,255,0.02); padding: 0.5rem; border-radius: 4px; border-left: 3px solid var(--primary);\"\u003e\r\n              💡 ขอใช้รถยนต์ของ อสป. (การจัดจัดสรรรถยนต์และพนักงานขับรถจะดำเนินการมอบหมายโดยผู้จัดรถ (L2) ในขั้นตอนพิจารณาอนุมัติ)\r\n            \u003c/div\u003e\r\n            \u003cdiv style=\"display: flex; gap: 1.5rem; margin-top: 0.5rem;\"\u003e\r\n              \u003clabel style=\"display: flex; align-items: center; gap: 0.25rem; font-weight: normal; cursor: pointer; font-size: 0.85rem;\"\u003e\r\n                \u003cinput type=\"checkbox\" id=\"check-car-go\" checked style=\"accent-color: var(--primary);\"\u003e (ไป)\r\n              \u003c/label\u003e\r\n              \u003clabel style=\"display: flex; align-items: center; gap: 0.25rem; font-weight: normal; cursor: pointer; font-size: 0.85rem;\"\u003e\r\n                \u003cinput type=\"checkbox\" id=\"check-car-back\" checked style=\"accent-color: var(--primary);\"\u003e (กลับ)\r\n              \u003c/label\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-group\" style=\"margin-top: 1.5rem;\"\u003e\r\n            \u003cdiv class=\"signature-license-grid\" id=\"signature-license-grid\"\u003e\r\n              \r\n              \u003c!-- Left: Driver\u0027s License file upload section (Visible only for Welfare Car) --\u003e\r\n              \u003cdiv id=\"driver-license-section\" style=\"display: none;\"\u003e\r\n                \u003clabel style=\"font-weight: bold; margin-bottom: 0.5rem; display: block;\"\u003eแนบสำเนาใบขับขี่ (รูปภาพหรือ PDF) \u003cspan style=\"color: var(--danger);\"\u003e*\u003c/span\u003e\u003c/label\u003e\r\n                \u003cdiv style=\"display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; height: 180px; border: 2px dashed var(--border-color); border-radius: 8px; background: rgba(255,255,255,0.02); padding: 1rem; box-sizing: border-box;\"\u003e\r\n                  \u003cbutton type=\"button\" class=\"btn btn-secondary btn-sm\" onclick=\"document.getElementById(\u0027input-driver-license\u0027).click()\" style=\"display: inline-flex; align-items: center; gap: 0.5rem;\"\u003e\r\n                    📁 เลือกไฟล์ใบขับขี่\r\n                  \u003c/button\u003e\r\n                  \u003cinput type=\"file\" id=\"input-driver-license\" accept=\"image/*,application/pdf\" style=\"display: none;\"\u003e\r\n                  \u003cspan id=\"driver-license-filename\" style=\"font-size: 0.8rem; color: var(--text-muted); text-align: center; max-width: 100%; display: block; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;\"\u003eยังไม่ได้เลือกไฟล์\u003c/span\u003e\r\n                  \u003cdiv id=\"driver-license-preview-container\" style=\"display: none; margin-top: 0.25rem;\"\u003e\r\n                    \u003cimg id=\"driver-license-preview\" src=\"\" style=\"max-width: 120px; max-height: 80px; border-radius: 6px; border: 1px solid var(--border-color); object-fit: contain;\"\u003e\r\n                  \u003c/div\u003e\r\n                \u003c/div\u003e\r\n              \u003c/div\u003e\r\n\r\n              \u003c!-- Right: Requester Signature section --\u003e\r\n              \u003cdiv id=\"signature-pad-section\"\u003e\r\n                \u003clabel style=\"font-weight: bold; margin-bottom: 0.5rem; display: block;\"\u003eลงลายมือชื่อผู้ขอใช้รถ\u003c/label\u003e\r\n                \u003cdiv class=\"signature-canvas-container\" style=\"margin-bottom: 0;\"\u003e\r\n                  \u003ccanvas id=\"canvas-requester-signature\" class=\"signature-canvas\"\u003e\u003c/canvas\u003e\r\n                  \u003cdiv class=\"signature-placeholder\" id=\"requester-sig-placeholder\"\u003eคลิกค้างแล้วลากเส้นเพื่อวาดลายมือชื่อสำหรับขออนุมัติ\u003c/div\u003e\r\n                  \u003cinput type=\"file\" id=\"upload-requester-sig\" accept=\"image/*\" style=\"display:none;\"\u003e\r\n                  \u003cbutton type=\"button\" class=\"btn btn-secondary signature-upload-btn\" onclick=\"document.getElementById(\u0027upload-requester-sig\u0027).click()\"\u003e📁 อัปโหลดภาพ\u003c/button\u003e\r\n                  \u003cbutton type=\"button\" class=\"btn btn-secondary signature-clear-btn\" id=\"btn-clear-requester-sig\"\u003eล้างลายเซ็น\u003c/button\u003e\r\n                \u003c/div\u003e\r\n              \u003c/div\u003e\r\n\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"modal-footer\"\u003e\r\n            \u003cbutton type=\"button\" class=\"btn btn-secondary\" id=\"btn-cancel-booking\"\u003eยกเลิก\u003c/button\u003e\r\n            \u003cbutton type=\"submit\" class=\"btn btn-primary\"\u003eส่งเสนอใบขออนุญาต\u003c/button\u003e\r\n          \u003c/div\u003e\r\n        \u003c/form\u003e\r\n      \u003c/div\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n\r\n  \u003c!-- MODAL 2: View Details \u0026 Approval Panel --\u003e\r\n  \u003cdiv class=\"modal-overlay\" id=\"modal-approval\"\u003e\r\n    \u003cdiv class=\"modal-box\" style=\"max-width: 600px;\"\u003e\r\n      \u003cdiv class=\"modal-header\"\u003e\r\n        \u003ch3\u003eข้อมูลและสายอนุมัติใบเสนอขอ\u003c/h3\u003e\r\n        \u003cbutton class=\"modal-close\" id=\"btn-close-approval\"\u003e\u0026times;\u003c/button\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"modal-body\"\u003e\r\n        \r\n        \u003c!-- Summary of request --\u003e\r\n        \u003cdiv style=\"background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; margin-bottom: 1.5rem;\"\u003e\r\n          \u003ch4 id=\"detail-title\" style=\"margin-bottom: 0.5rem; color: var(--primary);\"\u003eคำขอใช้รถยนต์ องค์การสะพานปลา\u003c/h4\u003e\r\n          \u003ctable style=\"width:100%; font-size:0.875rem; border-collapse:collapse;\"\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted); width:35%;\"\u003eผู้เสนอขอ:\u003c/td\u003e\r\n              \u003ctd id=\"detail-requester\" style=\"padding:0.25rem 0; font-weight:600;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eตำแหน่ง/สังกัด:\u003c/td\u003e\r\n              \u003ctd id=\"detail-office\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eเรื่อง/วัตถุประสงค์:\u003c/td\u003e\r\n              \u003ctd id=\"detail-purpose\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eสถานที่ปลายทาง:\u003c/td\u003e\r\n              \u003ctd id=\"detail-route\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eผู้ร่วมเดินทาง:\u003c/td\u003e\r\n              \u003ctd id=\"detail-passengers\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eช่วงเวลาการเดินทาง:\u003c/td\u003e\r\n              \u003ctd id=\"detail-time\" style=\"padding:0.25rem 0; font-size:0.8rem;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eประเภทการเดินทาง:\u003c/td\u003e\r\n              \u003ctd id=\"detail-travel-type\" style=\"padding:0.25rem 0; font-weight:600;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eรายละเอียดรถ/ค่าใช้จ่าย:\u003c/td\u003e\r\n              \u003ctd id=\"detail-car\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr id=\"detail-driver-row\"\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eพนักงานขับรถ:\u003c/td\u003e\r\n              \u003ctd id=\"detail-driver\" style=\"padding:0.25rem 0; font-weight:600;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr id=\"detail-driver-license-row\" style=\"display:none;\"\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eสำเนาใบขับขี่:\u003c/td\u003e\r\n              \u003ctd id=\"detail-driver-license\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n            \u003ctr id=\"detail-welfare-address-row\" style=\"display:none;\"\u003e\r\n              \u003ctd style=\"padding:0.25rem 0; color:var(--text-muted);\"\u003eที่อยู่ผู้ขอใช้รถ:\u003c/td\u003e\r\n              \u003ctd id=\"detail-welfare-address\" style=\"padding:0.25rem 0;\"\u003e-\u003c/td\u003e\r\n            \u003c/tr\u003e\r\n          \u003c/table\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003c!-- Approval pipeline history visual --\u003e\r\n        \u003cdiv\u003e\r\n          \u003ch4 id=\"approval-pipeline-title\" style=\"margin-bottom: 0.75rem; font-size: 1rem;\"\u003eลำดับการอนุมัติ (4 ขั้นตอนตามฟอร์ม อสป.)\u003c/h4\u003e\r\n          \u003cdiv class=\"approval-pipeline-detail\" id=\"approval-pipeline-container\"\u003e\r\n            \u003c!-- Steps injected dynamically --\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003c!-- Action Panel --\u003e\r\n        \u003cdiv id=\"approval-action-panel\" class=\"hidden\" style=\"margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;\"\u003e\r\n          \u003ch4 style=\"margin-bottom: 0.5rem; color: var(--warning); font-size: 1rem;\"\u003e✍️ พิจารณาคำขอ (ในบทบาทผู้ตรวจ/ผู้อนุมัติ)\u003c/h4\u003e\r\n          \r\n          \u003cdiv class=\"form-group\" id=\"fleet-admin-assign-box\" style=\"margin-bottom: 1.25rem; display:none; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 0.75rem; border-radius: 8px;\"\u003e\r\n            \u003clabel style=\"color:var(--warning); font-weight:bold;\"\u003eเฉพาะผู้จัดรถ (L2 ผู้จัดรถ): จัดรถยนต์และคนขับ\u003c/label\u003e\r\n            \r\n            \u003cdiv class=\"form-group\" style=\"margin-top:0.5rem;\" id=\"fleet-admin-car-select-group\"\u003e\r\n              \u003clabel for=\"assign-car\"\u003eเลือกรถยนต์ของ อสป. ที่ว่าง\u003c/label\u003e\r\n              \u003cselect id=\"assign-car\" class=\"form-control\"\u003e\r\n                \u003coption value=\"\"\u003e-- กรุณาเลือกรถยนต์ --\u003c/option\u003e\r\n              \u003c/select\u003e\r\n            \u003c/div\u003e\r\n\r\n            \u003cdiv class=\"form-group\" style=\"margin-top:0.5rem;\" id=\"fleet-admin-driver-group\"\u003e\r\n              \u003clabel for=\"assign-driver\"\u003eชื่อพนักงานขับรถปฏิบัติหน้าที่\u003c/label\u003e\r\n              \u003cinput type=\"text\" id=\"assign-driver\" class=\"form-control\" placeholder=\"ระบุชื่อพนักงานขับรถ\" value=\"นายดีเลิศ สมใจ\"\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-group\"\u003e\r\n            \u003clabel for=\"approval-comment\"\u003eความคิดเห็น / คำสั่งเพิ่มเติม\u003c/label\u003e\r\n            \u003cinput type=\"text\" id=\"approval-comment\" class=\"form-control\" placeholder=\"ความคิดเห็น เช่น เห็นชอบ, อนุมัติ\"\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-group\"\u003e\r\n            \u003clabel\u003eลงลายมือชื่อผู้อนุมัติ (วาดลายเซ็น)\u003c/label\u003e\r\n            \u003cdiv class=\"signature-canvas-container\"\u003e\r\n              \u003ccanvas id=\"canvas-approver-signature\" class=\"signature-canvas\"\u003e\u003c/canvas\u003e\r\n              \u003cdiv class=\"signature-placeholder\" id=\"approver-sig-placeholder\"\u003eกรุณาคลิกค้างแล้วลงลายมือชื่อดิจิทัล\u003c/div\u003e\r\n              \u003cinput type=\"file\" id=\"upload-approver-sig\" accept=\"image/*\" style=\"display:none;\"\u003e\r\n              \u003cbutton type=\"button\" class=\"btn btn-secondary signature-upload-btn\" onclick=\"document.getElementById(\u0027upload-approver-sig\u0027).click()\"\u003e📁 อัปโหลดภาพ\u003c/button\u003e\r\n              \u003cbutton type=\"button\" class=\"btn btn-secondary signature-clear-btn\" id=\"btn-clear-approver-sig\"\u003eล้างลายเซ็น\u003c/button\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv style=\"display:flex; justify-content:flex-end; gap:0.75rem; margin-top:1.5rem;\"\u003e\r\n            \u003cbutton class=\"btn btn-danger\" id=\"btn-reject-request\"\u003eปฏิเสธคำขอ\u003c/button\u003e\r\n            \u003cbutton class=\"btn btn-success\" id=\"btn-approve-request\"\u003eอนุมัติคำขอ\u003c/button\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n\r\n        \u003c!-- Special Edit Panel for L2 (Fleet Admin) when booking is approved or pending L3/L4 --\u003e\r\n        \u003cdiv id=\"fleet-admin-edit-panel\" style=\"display:none; margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 1rem; border-radius: 8px;\"\u003e\r\n          \u003ch4 style=\"margin-bottom: 0.5rem; color: var(--warning); font-size: 1rem;\"\u003e🔧 แก้ไขการจัดสรรยานพาหนะ (เฉพาะผู้จัดรถ L2)\u003c/h4\u003e\r\n          \r\n          \u003cdiv class=\"form-group\" style=\"margin-top:0.5rem;\"\u003e\r\n            \u003clabel for=\"edit-assign-car\"\u003eเลือกรถยนต์ของ อสป. ที่ว่าง หรือเลือก TAXI\u003c/label\u003e\r\n            \u003cselect id=\"edit-assign-car\" class=\"form-control\"\u003e\r\n              \u003c!-- Injected dynamically --\u003e\r\n            \u003c/select\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv class=\"form-group\" style=\"margin-top:0.5rem;\" id=\"fleet-admin-edit-driver-group\"\u003e\r\n            \u003clabel for=\"edit-assign-driver\"\u003eชื่อพนักงานขับรถปฏิบัติหน้าที่\u003c/label\u003e\r\n            \u003cinput type=\"text\" id=\"edit-assign-driver\" class=\"form-control\" placeholder=\"ระบุชื่อพนักงานขับรถ\"\u003e\r\n          \u003c/div\u003e\r\n\r\n          \u003cdiv style=\"display:flex; justify-content:flex-end; margin-top:1.25rem;\"\u003e\r\n            \u003cbutton class=\"btn btn-warning btn-sm\" id=\"btn-save-car-changes\"\u003e💾 บันทึกการเปลี่ยนแปลงยานพาหนะ\u003c/button\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n\r\n      \u003c/div\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n\r\n  \u003c!-- MODAL 3: Fill Taxi Details (For Requester L0) --\u003e\r\n  \u003cdiv class=\"modal-overlay\" id=\"modal-fill-taxi\"\u003e\r\n    \u003cdiv class=\"modal-box\" style=\"max-width: 450px;\"\u003e\r\n      \u003cdiv class=\"modal-header\"\u003e\r\n        \u003ch3\u003eกรอกข้อมูลระยะทางและค่าใช้จ่ายรถรับจ้าง\u003c/h3\u003e\r\n        \u003cbutton class=\"modal-close\" id=\"btn-close-fill-taxi\" type=\"button\"\u003e\u0026times;\u003c/button\u003e\r\n      \u003c/div\u003e\r\n      \u003cdiv class=\"modal-body\"\u003e\r\n        \u003cform id=\"form-fill-taxi\"\u003e\r\n          \u003cinput type=\"hidden\" id=\"fill-taxi-booking-id\"\u003e\r\n          \u003cdiv class=\"form-group\"\u003e\r\n            \u003clabel for=\"fill-distance\"\u003eระยะทางรวมประมาณ (กิโลเมตร)\u003c/label\u003e\r\n            \u003cinput type=\"number\" id=\"fill-distance\" class=\"form-control\" placeholder=\"ระบุกิโลเมตร\" required min=\"1\"\u003e\r\n          \u003c/div\u003e\r\n          \u003cdiv class=\"form-group\" style=\"margin-top: 1rem;\"\u003e\r\n            \u003clabel for=\"fill-price\"\u003eราคาเบิกจ่ายประมาณ (บาท)\u003c/label\u003e\r\n            \u003cinput type=\"number\" id=\"fill-price\" class=\"form-control\" placeholder=\"ระบุจำนวนเงินประมาณ\" required min=\"1\"\u003e\r\n          \u003c/div\u003e\r\n          \u003cdiv class=\"modal-footer\" style=\"margin-top: 1.5rem; padding: 0.5rem 0 0 0;\"\u003e\r\n            \u003cbutton type=\"button\" class=\"btn btn-secondary\" id=\"btn-cancel-fill-taxi\"\u003eยกเลิก\u003c/button\u003e\r\n            \u003cbutton type=\"submit\" class=\"btn btn-primary\"\u003e💾 บันทึกเสนอหัวหน้างาน\u003c/button\u003e\r\n          \u003c/div\u003e\r\n        \u003c/form\u003e\r\n      \u003c/div\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n      \u003cdiv id=\"modal-email-inbox\" class=\"modal-overlay\"\u003e\r\n        \u003cdiv class=\"modal-box\" style=\"max-width: 600px;\"\u003e\r\n          \u003cdiv class=\"modal-header\"\u003e\r\n            \u003ch3 style=\"display: flex; align-items: center; gap: 0.5rem;\"\u003e📧 กล่องข้อความแจ้งเตือนระบบ\u003c/h3\u003e\r\n            \u003cbutton id=\"btn-close-email-inbox\" class=\"modal-close\"\u003e\u0026times;\u003c/button\u003e\r\n          \u003c/div\u003e\r\n          \u003cdiv class=\"modal-body\" id=\"email-logs-list\" style=\"max-height: 60vh; overflow-y: auto; display: flex; flex-direction: column; gap: 1rem;\"\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n      \u003c/div\u003e\r\n\r\n      \u003c!-- MODAL 5: Export CSV Date Range (For L2) --\u003e\r\n      \u003cdiv id=\"modal-export-csv\" class=\"modal-overlay\"\u003e\r\n        \u003cdiv class=\"modal-box\" style=\"max-width: 450px;\"\u003e\r\n          \u003cdiv class=\"modal-header\"\u003e\r\n            \u003ch3 style=\"display: flex; align-items: center; gap: 0.5rem;\"\u003e📥 ส่งออกข้อมูลการจองรถยนต์\u003c/h3\u003e\r\n            \u003cbutton id=\"btn-close-export-csv\" class=\"modal-close\" onclick=\"document.getElementById(\u0027modal-export-csv\u0027).classList.remove(\u0027active\u0027)\"\u003e\u0026times;\u003c/button\u003e\r\n          \u003c/div\u003e\r\n          \u003cdiv class=\"modal-body\"\u003e\r\n            \u003cp style=\"font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.25rem;\"\u003e\r\n              กรุณาเลือกช่วงเวลาของวันเริ่มเดินทางที่ต้องการส่งออก (หากไม่ระบุวันที่ จะส่งออกข้อมูลการจองทั้งหมดในระบบ)\r\n            \u003c/p\u003e\r\n            \u003cdiv class=\"form-group\"\u003e\r\n              \u003clabel for=\"export-start-date\"\u003eตั้งแต่วันเริ่มเดินทาง\u003c/label\u003e\r\n              \u003cinput type=\"date\" id=\"export-start-date\" class=\"form-control\" style=\"width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-main); font-family: inherit; margin-top: 0.25rem;\"\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"form-group\" style=\"margin-top: 1rem;\"\u003e\r\n              \u003clabel for=\"export-end-date\"\u003eถึงวันเริ่มเดินทาง\u003c/label\u003e\r\n              \u003cinput type=\"date\" id=\"export-end-date\" class=\"form-control\" style=\"width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border-color); background: var(--bg-card); color: var(--text-main); font-family: inherit; margin-top: 0.25rem;\"\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class=\"modal-footer\" style=\"margin-top: 1.5rem; padding: 0.5rem 0 0 0; display: flex; gap: 0.5rem; justify-content: flex-end;\"\u003e\r\n              \u003cbutton type=\"button\" class=\"btn btn-secondary\" id=\"btn-cancel-export-csv\" onclick=\"document.getElementById(\u0027modal-export-csv\u0027).classList.remove(\u0027active\u0027)\"\u003eยกเลิก\u003c/button\u003e\r\n              \u003cbutton type=\"button\" class=\"btn btn-primary\" id=\"btn-submit-export-csv\" onclick=\"triggerExportBookings()\" style=\"background: #10b981; border-color: #10b981; color: white;\"\u003e📥 ส่งออก Excel (CSV)\u003c/button\u003e\r\n            \u003c/div\u003e\r\n          \u003c/div\u003e\r\n        \u003c/div\u003e\r\n      \u003c/div\u003e\r\n\r\n  \u003cscript src=\"flatpickr.min.js?v=1.0\"\u003e\u003c/script\u003e\r\n  \u003cscript src=\"flatpickr.th.js?v=1.0\"\u003e\u003c/script\u003e\r\n  \u003cscript src=\"app.js?v=5.3\"\u003e\u003c/script\u003e\r\n\u003c/body\u003e\r\n\u003c/html\u003e"
