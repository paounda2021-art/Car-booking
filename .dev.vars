# Cloudflare Pages / Workers Environment Variables Template
# Copy these keys and paste them into your Cloudflare Dashboard (Settings -> Environment variables)
# Or use this file locally when running wrangler dev

# The email provider to use: 'resend', 'sendgrid', or 'brevo'
EMAIL_PROVIDER=resend

# Your email provider API Key / Token
# Example for Resend: re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_API_KEY=your_api_key_here

# The verified sender email address in your provider account
EMAIL_FROM=procurement@fishmarket.co.th

# The display name of the email sender
EMAIL_FROM_NAME=ระบบจองรถ อสป.
